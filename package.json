{
  "name": "omnicode",
  "private": true,
  "version": "0.3.0",
  "description": "OmniCode monorepo: OpenCode plugin + launcher for the Omni workflow.",
  "repository": {
    "type": "git",
    "url": "https://github.com/edgyarmati/omnicode"
  },
  "homepage": "https://github.com/edgyarmati/omnicode#readme",
  "bugs": {
    "url": "https://github.com/edgyarmati/omnicode/issues"
  },
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "check": "node scripts/sync-version.mjs --check && npm run check --workspaces --if-present",
    "setup": "./scripts/setup",
    "sync-version": "node scripts/sync-version.mjs",
    "test": "npm run test --workspaces --if-present"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  }
}
