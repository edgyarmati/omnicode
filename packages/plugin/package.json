{
  "name": "@gedcode/plugin",
  "version": "0.3.0",
  "description": "OpenCode plugin that brings the Omni workflow into OpenCode.",
  "repository": {
    "type": "git",
    "url": "https://github.com/edgyarmati/gedcode"
  },
  "homepage": "https://github.com/edgyarmati/gedcode#readme",
  "bugs": {
    "url": "https://github.com/edgyarmati/gedcode/issues"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src/resources"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --experimental-strip-types test/**/*.test.ts"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.0.85"
  }
}
