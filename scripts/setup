#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

printf '==> GedCode setup: installing workspace dependencies\n'
npm install

printf '\n==> GedCode setup: building workspaces\n'
npm run build

printf '\n==> GedCode setup: linking local gedcode launcher\n'
npm link ./packages/launcher

if ! command -v gedcode >/dev/null 2>&1; then
  printf 'Warning: setup completed, but the gedcode command was not found on PATH.\n' >&2
  printf "You may need to restart your shell or add npm's global bin directory to PATH.\n" >&2
  exit 1
fi

printf '\n==> GedCode setup: installing RTK (token optimization proxy)\n'
if command -v rtk >/dev/null 2>&1; then
  printf 'RTK already installed: %s\n' "$(rtk --version 2>/dev/null || echo 'present')"
else
  if command -v brew >/dev/null 2>&1; then
    brew install rtk
  else
    printf 'Installing RTK via official installer...\n'
    curl -fsSL https://raw.githubusercontent.com/rtk-ai/rtk/refs/heads/master/install.sh | sh
  fi
  if command -v rtk >/dev/null 2>&1; then
    printf 'RTK installed successfully.\n'
  else
    printf 'Warning: RTK installation failed. GedCode works without it, but token savings will be unavailable.\n' >&2
    printf 'You can install RTK later: https://github.com/rtk-ai/rtk\n' >&2
  fi
fi

printf '\n==> GedCode setup complete\n'
printf 'Next steps:\n'
printf '  1. Optionally run: npm test\n'
printf '  2. Start GedCode: gedcode\n'
