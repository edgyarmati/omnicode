#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

printf '==> OmniCode setup: installing workspace dependencies\n'
npm install

printf '\n==> OmniCode setup: building workspaces\n'
npm run build

printf '\n==> OmniCode setup: linking local omnicode launcher\n'
npm link ./packages/launcher

if ! command -v omnicode >/dev/null 2>&1; then
  printf 'Warning: setup completed, but the omnicode command was not found on PATH.\n' >&2
  printf "You may need to restart your shell or add npm's global bin directory to PATH.\n" >&2
  exit 1
fi

printf '\n==> OmniCode setup complete\n'
printf 'Next steps:\n'
printf '  1. Optionally run: npm test\n'
printf '  2. Start OmniCode: omnicode\n'
